# Credenciais do Lefisc
LEFISC_USERNAME=seu_usuario_aqui
LEFISC_PASSWORD=sua_senha_aqui

# URLs
LEFISC_LOGIN_URL=https://www.lefisc.com.br/
LEFISC_NCM_URL=https://www.lefisc.com.br/ncm/conteudo.aspx

# Configurações da API
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# Scraper
HEADLESS=true
BROWSER_TIMEOUT_MS=30000

# Cache (em segundos) - NCMs mudam raramente, cache longo faz sentido
CACHE_TTL_SECONDS=86400
CACHE_MAX_SIZE=1000
